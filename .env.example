# Copy to .env and fill in.
#
# --- Option A: direct Anthropic API (default) ---
# The SDK reads ANTHROPIC_API_KEY automatically (or use `ant auth login`).
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8      # optional override

# --- Option B: route through Portkey (uses the portkey_ai SDK) ---
# Set PORTKEY_API_KEY to switch to the Portkey gateway path. PORTKEY_MODEL is
# your gateway's model slug. This matches the working snippet:
#     Portkey(base_url="https://portkeygateway.perficient.com/v1", api_key="...")
#     model="@dsvertex/anthropic.claude-3-5-sonnet-v2@20241022"
#
# PORTKEY_API_KEY=...
# PORTKEY_GATEWAY_URL=https://portkeygateway.perficient.com/v1
# PORTKEY_MODEL=@dsvertex/anthropic.claude-3-5-sonnet-v2@20241022
#
# Optional, only if your gateway needs them (the model slug often already
# carries the provider, so these are usually left unset):
# PORTKEY_VIRTUAL_KEY=...
# PORTKEY_CONFIG=...
